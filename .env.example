# =============================================================================
# OpenSource AI Engineer — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# All secrets are encrypted at rest using Fernet symmetric encryption.
# =============================================================================

# =============================================================================
# DATABASE — PostgreSQL 16
# =============================================================================
# Async connection string used by SQLAlchemy (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://ose_user:ose_password@localhost:5432/ose_db

# Used by docker-compose to initialize the database
POSTGRES_DB=ose_db
POSTGRES_USER=ose_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

# =============================================================================
# REDIS — Job queue, caching, pub/sub
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# =============================================================================
# CHROMADB — Vector store for RAG (code embeddings)
# =============================================================================
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
# Port exposed on host (internal container port is always 8000)
CHROMADB_EXTERNAL_PORT=8001

# =============================================================================
# SECURITY — CHANGE ALL OF THESE IN PRODUCTION
# =============================================================================

# JWT signing secret — minimum 32 characters, use a random value
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-min-32-chars-change-this

# Fernet key — used to encrypt GitHub tokens at rest in the database
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# JWT algorithm
ALGORITHM=HS256

# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# LLM CONFIGURATION
# Priority: Gemini → Ollama (local fallback) → OpenAI (optional)
# =============================================================================

# --- Gemini (recommended — free tier: 1M tokens/day) ---
# Get your free key at: https://ai.google.dev
# Leave empty to skip Gemini and use Ollama instead
GEMINI_API_KEY=

# Gemini model to use
# Options: gemini-2.5-flash (recommended), gemini-2.5-pro, gemini-1.5-flash
GEMINI_MODEL=gemini-2.5-flash

# --- Ollama (100% local — no API key required) ---
# Install Ollama: https://ollama.ai
# Then run: ollama pull qwen3:14b
# When running inside Docker, use host.docker.internal to reach host
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# --- OpenAI (optional — costs money) ---
# Leave empty to not use OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Anthropic (optional — costs money) ---
# Leave empty to not use Anthropic
ANTHROPIC_API_KEY=

# =============================================================================
# GITHUB — Required for PR creation and issue discovery
# =============================================================================

# Fine-grained Personal Access Token (PAT)
# Required permissions: Contents (Read & Write), Issues (Read), Pull Requests (Read & Write)
# Create at: https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=

# HMAC secret for verifying GitHub webhook payloads
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=

# Your GitHub username (used for PR attribution and avatar)
GITHUB_USERNAME=

# GitHub App ID (optional — alternative to PAT for higher rate limits)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=

# =============================================================================
# NOTIFICATIONS — All optional; system works without any of these
# =============================================================================

# --- Telegram ---
# Create a bot via @BotFather → get token
# Then message the bot and get your chat ID via: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Discord ---
# Create a webhook in your Discord server:
# Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# --- Email (SMTP) ---
# Using Gmail: enable 2FA, then create an App Password
# (Google Account → Security → App Passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
NOTIFICATION_EMAIL=

# =============================================================================
# AGENT SETTINGS
# =============================================================================

# How many times an agent retries on failure before giving up
MAX_RETRIES=3

# Seconds before a sandbox execution is killed (prevents runaway code)
SANDBOX_TIMEOUT_SECONDS=120

# Memory limit for each sandbox container (MB)
SANDBOX_MEMORY_MB=512

# Maximum number of agent pipelines running concurrently
MAX_CONCURRENT_AGENTS=3

# How often the issue discovery agent runs (hours)
ISSUE_DISCOVERY_INTERVAL_HOURS=24

# How often the repo discovery agent scans for new repositories (days)
REPO_DISCOVERY_INTERVAL_DAYS=7

# Maximum GitHub API requests per hour (GitHub allows 5000/hr for authenticated)
GITHUB_API_RATE_LIMIT=4000

# =============================================================================
# SERVICE PORTS (host-side port bindings)
# =============================================================================
BACKEND_PORT=8000
FRONTEND_PORT=3000

# =============================================================================
# FRONTEND
# =============================================================================
# API base URL as seen from the browser (not the Docker internal network)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable the Innovation Agent (proactively generates RFC proposals)
ENABLE_INNOVATION_AGENT=true

# Enable Google Summer of Code repository discovery
ENABLE_GSOC_DISCOVERY=true

# Enable CNCF (Cloud Native Computing Foundation) project discovery
ENABLE_CNCF_DISCOVERY=true

# Enable Apache Foundation project discovery
ENABLE_APACHE_DISCOVERY=true

# Enable Docker sandbox for safe code execution (disable if Docker unavailable)
ENABLE_SANDBOX=true

# Enable PR creation (set to false for pure analysis mode, no PRs created)
ENABLE_PR_CREATION=true

# Only create DRAFT PRs (highly recommended — human review before publishing)
DRAFT_PRS_ONLY=true

# =============================================================================
# LOGGING & OBSERVABILITY
# =============================================================================
LOG_LEVEL=INFO
ENVIRONMENT=production

# Sentry DSN (optional — for error tracking in production)
SENTRY_DSN=

# =============================================================================
# LEARNING AGENT
# =============================================================================
# How often the XGBoost model retrains on PR outcomes (hours)
LEARNING_RETRAIN_INTERVAL_HOURS=168

# Minimum number of closed PRs required before retraining
LEARNING_MIN_SAMPLES=50
